reportix.shop, www.reportix.shop {
    encode zstd gzip

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /admin/* {
        reverse_proxy backend:8000
    }

    handle_path /static/* {
        root * /srv/static
        file_server
    }

    handle_path /media/* {
        root * /srv/media
        file_server
    }

    handle {
        root * /usr/share/nginx/html
        try_files {path} /index.html
        file_server
    }
}
